## ==================================================
## MAIN
## ==================================================
def main():
    parser=argparse.ArgumentParser(add_help=False)
    parser.add_argument("-a", "--all",dest="a",action="store_true")
    parser.add_argument("-l","--long",dest="l",action="store_true")
    parser.add_argument("-s","--size",dest="s",action="store_true")
    parser.add_argument("paths",nargs="*")
    args=parser.parse_args()

    paths=args.paths or ["."]
    objs=[Path(p) for p in paths]

    if all(o.exists() and o.is_file() for o in objs):
        if args.s: objs=sorted(objs,key=lambda x:x.stat().st_size,reverse=True)
        else:      objs=sorted(objs,key=lambda x:natural_key(x.name))
        
        for o in objs:
            st=o.stat()
            print(long_line(o,st) if args.l else short_line(o,st))
        print()
        return
    
    for p in paths: list_path(p,args)
    print()
    
## ==================================================
## CORE LISTING LOGIC
## ==================================================
def list_path(p,args):
    p=Path(p)
    if not p.exists():
        print(f"{p}: No such file or directory")
        return

    if p.is_file():
        st=p.stat()
        print(long_line(p,st) if args.l else short_line(p,st))
        return

    entries=list(p.iterdir())
    if not args.a: entries=[e for e in entries if not e.name.startswith(".")]

    dirs=sorted((e for e in entries if e.is_dir()),key=lambda x:natural_key(x.name))
    if args.s: files=sorted((e for e in entries if e.is_file()), key=lambda x:x.stat().st_size, reverse=True)
    else:      files=sorted((e for e in entries if e.is_file()), key=lambda x:natural_key(x.name))
    ordered=[*dirs,*files]

    if args.l:
        for e in ordered: print(long_line(e,e.stat()))
        return

    items=[short_line(e,e.stat()) for e in ordered]

    print()
    nfiles=len(files)
    ndirs=len(dirs)
    print(f"{WHITE}{p.resolve()}{RESET} | ndirs = {ndirs}, nfiles = {nfiles}")
    print_columns(items)

## ==================================================
## FORMATTERS
## ==================================================
def long_line(path,st):
    perms=stat.filemode(st.st_mode)
    user=pwd.getpwuid(st.st_uid).pw_name
    group=grp.getgrgid(st.st_gid).gr_name
    size=human(st.st_size).rjust(8)
    mtime=time.strftime("%b %d %H:%M",time.localtime(st.st_mtime))
    return f"{perms} {user:8} {group:8} {size} {mtime} {styled(path)}"

def short_line(path,st):
    if path.is_dir(): return styled(path)
    return f"{styled(path)} {WHITE}{ITALICS}{DIM}{human(st.st_size)}{RESET}"

## ==================================================
## STYLING
## ==================================================
def styled(path):
    name = path.name
    lower = name.lower()

    is_hidden = name.startswith(".")
    is_backup = name.endswith("~") or (
        name.startswith("#") and name.endswith("#")
    )

    ## detect extension (supports tar.gz)
    if path.is_dir(): base = TYPES["dir"]
    else:
        if lower.endswith(".tar.gz"): ext = "tar"
        else:
            parts = lower.rsplit(".", 1)
            ext = parts[1] if len(parts) == 2 else ""
        base = TYPES.get(ext, TYPES["default"])

    color = base["color"]
    icon = base["icon"]

    if is_hidden or is_backup: return f"{icon} {color}{DIM}{name}{RESET}"
    return f"{icon} {color}{name}{RESET}"

## ==================================================
## COLUMN LAYOUT
## ==================================================
def print_columns(items):
    if not items: return

    term_width = shutil.get_terminal_size((80,20)).columns
    lengths = [display_len(i) for i in items]

    for ncols in range(len(items), 0, -1):
        nrows = (len(items) + ncols - 1) // ncols

        col_widths = []
        total_width = 0

        for c in range(ncols):
            maxw = 0
            for r in range(nrows):
                i = r + c * nrows
                if i < len(items) and lengths[i] > maxw:
                    maxw = lengths[i]
            col_widths.append(maxw)
            total_width += maxw + 2

        total_width -= 2  # no padding after last column

        if total_width <= term_width:
            break

    for r in range(nrows):
        row = ""
        for c in range(ncols):
            i = r + c * nrows
            if i >= len(items): continue
            item = items[i]
            pad = col_widths[c] - lengths[i]
            row += item
            if c != ncols - 1:
                row += " " * (pad + 2)
        print(row)

## ==================================================
## UTILITIES
## ==================================================
def human(size):
    for u in ("B","KB","MB","GB","TB"):
        if size<1024: return f"{size:.1f}{u}"
        size/=1024
    return f"{size:.1f}PB"

def natural_key(name):
    return [int(x) if x.isdigit() else x.lower()
            for x in re.split(r"([0-9]+)",name)]

def display_len(s):
    clean=re.sub(r"\x1b\[[0-9;]*m","",s)
    return wcswidth(clean)

## ==================================================
if __name__=="__main__": main()
