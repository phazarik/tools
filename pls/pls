# Description
# -----------------------------------------------------------------------------
# pls is a fast, minimal, and visually enhanced alternative to the Unix ls
# command. It provides structured directory listing with icons, ANSI colors,
# intelligent sorting, and improved column formatting.
#
# -----------------------------------------------------------------------------
# Features
# -----------------------------------------------------------------------------
# - Directory-first ordering
# - Natural sorting (file2 before file10)
# - Optional size-based sorting (-s)
# - Long listing mode (-l)
# - Hidden file support (-a)
# - Human-readable file sizes
# - ANSI color styling
# - Icon-based file type recognition
# - Special handling for:
#     * .tar.gz archives
#     * Hidden files (.)
#     * Backup files (~, #file#)
# - Automatic terminal-width aware column layout
# - Proper Unicode display width handling (wcwidth)
#
# -----------------------------------------------------------------------------
# Usage
# -----------------------------------------------------------------------------
#   pls
#   pls -a
#   pls -l
#   pls -s
#   pls <files_or_directories>
#
# =============================================================================

import argparse, stat, pwd, grp, time, re, shutil
from pathlib import Path
from wcwidth import wcswidth

## === ANSI ===
RESET="\033[0m"
BOLD="\033[1m"
DIM="\033[2m"
ITALICS="\033[3m"

BLUE="\033[34m"
CYAN="\033[36m"
MAGENTA="\033[35m"
RED="\033[31m"
YELLOW="\033[33m"
GRAY="\033[0;90m"
WHITE="\033[37m"

## === TYPE CONFIG ===
TYPES = {
